# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ---------------------------------------------------------------------------

# MongoDB Atlas connection string (free M0 tier).
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/sinno-football?retryWrites=true&w=majority
MONGODB_URI=

# Secret used to sign JWT session tokens. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# How long a login session lasts. Default 30 days.
SESSION_MAX_AGE_DAYS=30

# Cloudinary (QR code + avatar image uploads). From your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Web Push (VAPID) keys for notifications. Generate with:
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# A mailto: or https: URL identifying the push sender (required by the spec).
VAPID_SUBJECT=mailto:admin@example.com

# Shared secret protecting the cron endpoint (/api/cron/check-deadlines).
# The external cron pinger (e.g. cron-job.org) must send this as a header/query.
CRON_SECRET=
